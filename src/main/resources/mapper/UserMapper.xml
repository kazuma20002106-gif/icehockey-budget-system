<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.miyazaki.icehockey.budgetsystem.mapper.UserMapper">
    <select id="findAll" resultType="com.miyazaki.icehockey.budgetsystem.model.User">
        SELECT * FROM users ORDER BY id
    </select>

    <select id="findById" resultType="com.miyazaki.icehockey.budgetsystem.model.User">
        SELECT * FROM users WHERE id = #{id}
    </select>

    <select id="findByName" resultType="com.miyazaki.icehockey.budgetsystem.model.User">
        SELECT * FROM users WHERE name = #{name} LIMIT 1
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO users (name, phone_number) VALUES (#{name}, #{phoneNumber})
    </insert>

    <update id="update">
        UPDATE users SET name = #{name}, phone_number = #{phoneNumber} WHERE id = #{id}
    </update>
</mapper>
