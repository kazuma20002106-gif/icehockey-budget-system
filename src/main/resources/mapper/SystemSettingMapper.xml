<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.miyazaki.icehockey.budgetsystem.mapper.SystemSettingMapper">
    <select id="findByKey" resultType="com.miyazaki.icehockey.budgetsystem.model.SystemSetting">
        SELECT * FROM system_settings WHERE setting_key = #{key}
    </select>

    <insert id="upsert">
        INSERT INTO system_settings (setting_key, setting_value)
        VALUES (#{settingKey}, #{settingValue})
        ON DUPLICATE KEY UPDATE setting_value = #{settingValue}
    </insert>
</mapper>
